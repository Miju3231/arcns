# ─── Arc Testnet ──────────────────────────────────────────────────────────────
# RPC URL for Arc Testnet
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network

# Chain ID — Arc Testnet = 5042002
VITE_ARC_CHAIN_ID=5042002

# Block explorer URL
VITE_EXPLORER_URL=https://testnet.arcscan.app

# ─── Smart Contract Addresses (Arc Testnet) ───────────────────────────────────
# ENS-compatible registry
VITE_REGISTRY_ADDRESS=0xD7644411C393D1BE031889A809886d55D1164Dac

# ETHRegistrarController (handles commit+register flow)
VITE_REGISTRAR_ADDRESS=0x6Ce3d7195aDFF59e3C5DCb8077c2C5707AcBC31c

# Public resolver
VITE_RESOLVER_ADDRESS=0xB1e687E9fBe7Ae822302a9479987c1CD23B28C1A

# Reverse resolver
VITE_REVERSE_RESOLVER_ADDRESS=0x346494613367891A144F7e9336B0F712b887b47E

# ─── WalletConnect ────────────────────────────────────────────────────────────
# REQUIRED for WalletConnect/mobile wallets.
# 1. Go to https://cloud.reown.com and create a free project
# 2. Add your Vercel deployment URL to the project's allowed origins
# 3. Paste the Project ID below
# Without this, only MetaMask browser extension will work.
VITE_WALLETCONNECT_PROJECT_ID=854cebe8c80cb56749e509d73fc1cbb7
VITE_REGISTRY_DEPLOY_BLOCK=9004925
